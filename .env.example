TELEGRAM_BOT_TOKEN=colle_ton_token_ici
TELEGRAM_CHAT_ID=colle_ton_chat_id_ici

# "daemon" = tourne en continu | "once" = un seul scan puis arrêt
RUN_MODE=daemon
POLL_MINUTES=15
SMART_SCHEDULE=1
DAY_POLL_MINUTES=5
NIGHT_POLL_MINUTES=15
DAY_START_HOUR=8
DAY_END_HOUR=22
NOTIFY_EMPTY_SCAN=1
EMPTY_SCAN_NOTIFY_EVERY=3
DAILY_RECAP_ENABLED=1
DAILY_RECAP_HOUR=22

# Limite de résultats récupérés par source et par cycle
MAX_RESULTS_PER_SOURCE=25
HTTP_TIMEOUT_SECONDS=25

# Optionnel, exemple: "Nouvelle-Aquitaine" ou "France"
REGION_FILTER=

# Personnalisation des filtres (liste séparée par virgules)
TITLE_KEYWORDS=alternance,alternant,apprenti
DESC_KEYWORDS=solidworks,catia,creo,topsolid,solidedge
